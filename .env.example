# ── Frontend (.env in /globe-explorer root) ──────────────────
# Copy this to .env and fill in your values.

# Base URL of your Express backend
VITE_API_BASE=http://localhost:4000

# The column in your MySQL table used to look up a country
# e.g. iso_code, country_code, id, name
VITE_KEY_COLUMN=iso_code

# Set to "false" to use your real API instead of mock data
VITE_USE_MOCK=true
