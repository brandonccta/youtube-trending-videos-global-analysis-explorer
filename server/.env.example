# Supabase PostgreSQL Database Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# SUPABASE CONNECTION (Required)
# ============================================
# Get your connection string from Supabase:
# 1. Go to Supabase Dashboard -> Settings -> Database
# 2. Scroll to "Connection string" section
# 3. Click "Transaction" tab (recommended for serverless/Vercel)
#    OR "URI" tab (for direct connection)
# 4. Copy the connection string and replace [YOUR-PASSWORD] with your database password

# Option 1: Transaction Pooler (Recommended for Vercel/serverless)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Option 2: Direct Connection (Alternative)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=4000

# ============================================
# CORS CONFIGURATION
# ============================================
# For local development
CORS_ORIGIN=http://localhost:3000

# For production (update after deploying to Vercel)
# CORS_ORIGIN=https://your-app.vercel.app

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Replace [YOUR-PROJECT-REF] with your Supabase project reference
# 3. Replace [YOUR-PASSWORD] with your Supabase database password
# 4. Replace [REGION] with your region (e.g., us-east-1, eu-west-1)
# 5. Never commit .env to git (it's in .gitignore)

# Example (Transaction Pooler):
# DATABASE_URL=postgresql://postgres.trcqhmmpfkobxpustbgj:MySecurePassword123@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Example (Direct Connection):
# DATABASE_URL=postgresql://postgres:MySecurePassword123@db.trcqhmmpfkobxpustbgj.supabase.co:5432/postgres
