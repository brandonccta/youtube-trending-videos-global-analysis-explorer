# ── Backend (server/.env) ─────────────────────────────────────
# Copy this to server/.env and fill in your credentials.

PORT=4000

# ── SSH Tunnel (required to reach the remote MySQL) ───────────
SSH_ENABLED=true

# Jump host (first hop)
SSH_JUMP_HOST=bolt.cs.ucr.edu
SSH_JUMP_PORT=22
SSH_JUMP_USER=[Your NetID]

# Target host (where MySQL runs)
SSH_TARGET_HOST=class-148.cs.ucr.edu
SSH_TARGET_PORT=22
SSH_TARGET_USER=cs179g

# ── MySQL (on the target host) ────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=youtube_analysis